# ── API keys & secrets ────────────────────────────────────────────────────────
.env
.envrc

# ── Virtual environment ────────────────────────────────────────────────────────
.venv
env/
venv/

# ── ChromaDB vector store (large, regenerated by main.py) ─────────────────────
chroma_store/

# ── Python cache ───────────────────────────────────────────────────────────────
__pycache__/
*.py[codz]
*$py.class

# ── uv ─────────────────────────────────────────────────────────────────────────
# uv.lock is kept in version control for reproducible installs

# ── Testing & coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── IDE ────────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── OS ─────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Misc ───────────────────────────────────────────────────────────────────────
*.log
.ruff_cache/
